#!/usr/bin/env bash
set -euo pipefail

# stash — installation script
#
# usage:  curl -fsSL https://raw.githubusercontent.com/pbshgthm/stash/main/install | bash
#         ./install        (when run from a local clone)
#
# clones the stash repo to ~/.local/share/stash and symlinks each tool
# into ~/.local/bin/<name>. re-running pulls the latest.

REPO_URL="https://github.com/pbshgthm/stash.git"
SHARE_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/stash"
BIN_DIR="${XDG_BIN_HOME:-$HOME/.local/bin}"

# --- style ---
if [[ -t 1 ]]; then
    B=$'\033[1m'  D=$'\033[2m'  G=$'\033[32m'  R=$'\033[31m'
    C=$'\033[36m' W=$'\033[37m' X=$'\033[0m'
else
    B= D= G= R= C= W= X=
fi

_ok()   { printf '%s\n' "${G}ok${X}  ${D}$*${X}"; }
_err()  { printf '%s\n' "${R}error${X}  $*" >&2; }
_info() { printf '%s\n' "${D}$*${X}"; }
_die()  { _err "$*"; exit 1; }

# --- banner ---
printf '%s' "${B}${C}"
cat <<'BANNER'
       _____              ______
_________  /______ __________  /_
__  ___/  __/  __ `/_  ___/_  __ \
_(__  )/ /_ / /_/ /_(__  )_  / / /
/____/ \__/ \__,_/ /____/ /_/ /_/
BANNER
printf '%s' "${X}"
printf '\n  %sstash%s %s— single-file bash tools for macOS%s\n\n' "$B" "$X" "$D" "$X"

# --- preflight ---
command -v git >/dev/null 2>&1 || _die "git is required but not found in PATH"

# --- clone or update ---
if [[ -d $SHARE_DIR/.git ]]; then
    _info "stash already at $SHARE_DIR — pulling latest"
    git -C "$SHARE_DIR" pull --ff-only --quiet
else
    _info "cloning stash → $SHARE_DIR"
    mkdir -p "$(dirname "$SHARE_DIR")"
    git clone --quiet "$REPO_URL" "$SHARE_DIR"
fi

# --- link ---
mkdir -p "$BIN_DIR"

linked=0
for f in "$SHARE_DIR"/*; do
    [[ -f $f && -x $f ]] || continue
    name=$(basename "$f")
    # skip files with extensions, dotfiles, and the meta scripts themselves
    [[ $name == *.* || $name == .* ]] && continue
    [[ $name == install || $name == uninstall ]] && continue
    ln -sf "$f" "$BIN_DIR/$name"
    _ok "linked ${B}$name${X}${D} → $BIN_DIR/$name${X}"
    linked=$((linked + 1))
done

[[ $linked -gt 0 ]] || _die "no executables found in $SHARE_DIR"

# --- PATH check ---
case ":$PATH:" in
    *":$BIN_DIR:"*) ;;
    *)
        printf '\n'
        printf '%sheads up:%s %s is not on your PATH\n' "$R" "$X" "$BIN_DIR"
        _info "  add this to your shell rc (e.g. ~/.zshrc or ~/.bashrc):"
        printf '\n    %sexport PATH="%s:$PATH"%s\n\n' "$C" "$BIN_DIR" "$X"
        ;;
esac

# --- next steps ---
printf '\n'
_ok "${B}stash installed${X}${D} — $linked tool(s) linked${X}"
_info "  next: run ${B}<tool> --help${X}${D} to see what it does${X}"
_info "  service tools also need ${B}<tool> init${X}${D} for first-time setup${X}"
