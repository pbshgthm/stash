#!/usr/bin/env bash
set -euo pipefail

# install — generic installer for any tool in stash.
#
# usage:
#   curl -fsSL https://raw.githubusercontent.com/pbshgthm/stash/main/install | bash -s <tool>
#   ./install <tool>     (when run from a local clone)
#
# Drops tools/<tool>/<tool> into ~/.local/bin/<tool>. After-install hints (e.g.
# `loco init` for service tools) are tool-specific and live in each README.

REPO_RAW="https://raw.githubusercontent.com/pbshgthm/stash/main"
BIN_DIR="${XDG_BIN_HOME:-$HOME/.local/bin}"

# --- style ---
if [[ -t 1 ]]; then
    B=$'\033[1m'  D=$'\033[2m'  G=$'\033[32m'  R=$'\033[31m'
    C=$'\033[36m' X=$'\033[0m'
else
    B= D= G= R= C= X=
fi

_ok()   { printf '%s\n' "${G}ok${X}  ${D}$*${X}"; }
_err()  { printf '%s\n' "${R}error${X}  $*" >&2; }
_info() { printf '%s\n' "${D}$*${X}"; }
_die()  { _err "$*"; exit 1; }

# --- args ---
TOOL="${1:-}"
if [[ -z "$TOOL" ]]; then
    _err "usage: install <tool>"
    _info "  available: loco, pluck, mint"
    exit 1
fi

# Block path tricks; tool names are short lowercase words by convention.
[[ "$TOOL" =~ ^[a-z][a-z0-9-]*$ ]] || _die "invalid tool name: $TOOL"

# --- preflight ---
command -v curl >/dev/null 2>&1 || _die "curl is required but not found in PATH"

# --- download ---
mkdir -p "$BIN_DIR"
target="$BIN_DIR/$TOOL"
tmp="$target.tmp.$$"
trap 'rm -f "$tmp"' EXIT

raw_url="$REPO_RAW/tools/$TOOL/$TOOL"
_info "fetching ${B}$TOOL${X}${D} → $target${X}"
if ! curl -fsSL "$raw_url" -o "$tmp"; then
    _die "couldn't fetch $raw_url — does the tool exist?"
fi
chmod +x "$tmp"
mv -f "$tmp" "$target"

_ok "installed ${B}$TOOL${X}"

# --- PATH check ---
case ":$PATH:" in
    *":$BIN_DIR:"*) ;;
    *)
        printf '\n'
        printf '%sheads up:%s %s is not on your PATH\n' "$R" "$X" "$BIN_DIR"
        _info "  add this to your shell rc (e.g. ~/.zshrc or ~/.bashrc):"
        printf '\n    %sexport PATH="%s:$PATH"%s\n\n' "$C" "$BIN_DIR" "$X"
        ;;
esac

# --- next steps ---
printf '\n'
_info "next: ${B}$TOOL --help${X}"
