---
import Terminal from "../layouts/Terminal.astro";
import Banner from "../components/Banner.astro";
import ToolItem from "../components/ToolItem.astro";
import { getUtils } from "../lib/utils";
import heroBanner from "../assets/stash.txt?raw";

const cards = await getUtils();
---

<Terminal title="stash">
  <!-- hero -->
  <section>
    <div
      class="mb-8 flex items-center gap-3 font-mono text-[11.5px] uppercase tracking-[0.22em] text-faint"
    >
      <span class="h-px w-8 bg-line-strong"></span>
      <span>a personal stash</span>
    </div>

    <div class="overflow-x-auto pb-2">
      <Banner text={heroBanner} size="xl" tone="fg" />
    </div>

    <div class="mt-14 max-w-xl">
      <p class="serif text-[26px] leading-[1.3] text-fg-soft sm:text-[29px]">
        single-file bash tools for macOS.
      </p>
      <p class="mt-4 text-[15px] leading-relaxed text-muted">
        small utilities i built for myself, one self-contained script each,
        easy to install, easy to delete, easy to read.
      </p>
      <p class="mt-6 font-mono text-[12.5px] text-faint">
        by{" "}
        <a
          href="https://github.com/pbshgthm"
          target="_blank"
          rel="noreferrer"
          class="text-muted underline-offset-4 transition-colors hover:text-fg hover:underline"
        >
          Poobesh Gowtham
        </a>
      </p>
    </div>
  </section>

  <!-- tools, quiet list; click a row for the blurb + install -->
  <section class="mt-28">
    <div
      class="border-b border-line-strong pb-3.5 font-mono text-[11.5px] uppercase tracking-[0.22em] text-faint"
    >
      tools
    </div>

    {
      cards.map((c, i) => (
        <ToolItem
          slug={c.slug}
          tagline={c.tagline}
          blurb={c.blurb}
          color={c.color}
          index={i}
        />
      ))
    }
  </section>

  <!-- how it works, one honest line, not a feature grid -->
  <section class="mt-20">
    <p class="max-w-2xl text-[14.5px] leading-relaxed text-muted">
      each tool is one bash file. installing copies it to <code
        class="rounded border border-line bg-bg-soft px-1.5 py-0.5 font-mono text-[13px] text-fg-soft"
        >~/.local/bin</code
      >; removing it is just <code
        class="rounded border border-line bg-bg-soft px-1.5 py-0.5 font-mono text-[13px] text-fg-soft"
        >rm</code
      >. read it, change it, keep what's useful.
    </p>
  </section>
</Terminal>
