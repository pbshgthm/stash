---
import { render } from "astro:content";
import Terminal from "../layouts/Terminal.astro";
import Banner from "../components/Banner.astro";
import { summarize } from "../lib/parse";
import { describe } from "../lib/descriptions";
import { colorOf } from "../lib/colors";
import { getUtilEntries, getUtilStats } from "../lib/utils";

export async function getStaticPaths() {
  const entries = await getUtilEntries();
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const parsed = summarize(entry.body ?? "");
const banner = parsed.banner;
const { tagline } = describe(entry.id, parsed);
const color = colorOf(entry.id);

const stats = getUtilStats(entry.id);
const sourceUrl = `https://github.com/pbshgthm/stash/blob/main/tools/${entry.id}/${entry.id}`;
---

<Terminal title={`${entry.id}, stash`} description={tagline}>
  <div class="mx-auto max-w-3xl" style={`--util-color: ${color}`}>
    <!-- breadcrumb -->
    <a
      href={import.meta.env.BASE_URL}
      class="inline-flex items-baseline gap-2 font-mono text-[13px] text-muted transition-colors hover:text-fg"
    >
      <span>←</span>
      <span>stash</span>
      <span class="text-line-strong">/</span>
      <span class="text-fg-soft">{entry.id}</span>
    </a>

    <!-- hero -->
    <section class="mt-12">
      <div class="overflow-x-auto pb-2">
        <Banner text={banner} size="xl" color={color} />
      </div>

      <div class="mt-10 flex flex-wrap items-baseline gap-x-4 gap-y-1.5">
        <h1 class="font-mono text-[21px] font-medium tracking-tight text-fg">
          {entry.id}
        </h1>
        <p class="serif text-[21px] leading-snug text-fg-soft">{tagline}</p>
      </div>

      <div
        class="mt-6 flex items-center gap-x-3 font-mono text-[12.5px] tabular text-faint"
      >
        <span>{stats.lines} lines</span>
        <span class="text-line-strong">·</span>
        <a
          href={sourceUrl}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-1.5 text-muted transition-colors hover:text-fg"
        >
          <span>view source</span>
          <span aria-hidden="true">↗</span>
        </a>
      </div>
    </section>

    <!-- separator -->
    <div class="mt-14 mb-12 h-px bg-line"></div>

    <!-- doc body -->
    <article class="md md--util">
      <Content />
    </article>
  </div>
</Terminal>
